@model IEnumerable<LibPro.Models.Patrons>

@{
    ViewData["Title"] = "借閱人列表";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-end mb-3">

        <div>
            <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-people-fill me-2"></i>@ViewData["Title"]</h3>
        </div>

        <div class="d-flex align-items-center gap-3">

            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
                <i class="bi bi-person-plus-fill"></i> 新增借閱人
            </a>

            <form asp-action="Index" method="get" class="d-flex align-items-center shadow-sm bg-white border rounded-3 px-3 py-2 mb-0">
                <i class="bi bi-funnel-fill text-muted me-2"></i>
                <label class="fw-bold text-muted text-nowrap mb-0 me-2">狀態篩選：</label>
                <select name="statusFilter" class="form-select form-select-sm border-0 bg-light fw-bold text-primary"
                        asp-items="ViewBag.StatusFilter" onchange="this.form.submit()" style="cursor: pointer; min-width: 130px;">
                    <option value="">-- 全部狀態 --</option>
                </select>
            </form>

        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0 table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.Gender)</th>
                        <th>聯絡資訊</th>
                        <th>@Html.DisplayNameFor(model => model.Profession)</th>
                        <th>@Html.DisplayNameFor(model => model.City)</th>
                        <th>狀態</th>
                        <th class="text-end pe-4">管理操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark fs-6">
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>

                            <td>
                                @Html.DisplayFor(modelItem => item.Gender)
                            </td>

                            <td>
                                <div><i class="bi bi-telephone-fill text-muted small"></i> @item.Phone</div>
                                <div class="text-muted small"><i class="bi bi-envelope-fill text-muted small"></i> @item.Email</div>
                            </td>

                            <td>
                                @Html.DisplayFor(modelItem => item.Profession)
                            </td>

                            <td>
                                @Html.DisplayFor(modelItem => item.City.CityName)
                            </td>

                            <td>
                                <span class="badge bg-secondary">
                                    @Html.DisplayFor(modelItem => item.PatronsStatus.StatusName)
                                </span>
                            </td>

                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.PatronID" class="btn btn-outline-primary">編輯</a>
                                <a asp-action="Details" asp-route-id="@item.PatronID" class="btn btn-outline-info">詳細</a>

                                @if (item.PtrStatus == 1)
                                {
                                    <form asp-action="UpdateStatus" asp-route-id="@item.PatronID" asp-route-status="4" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger" onclick="return confirm('確定要將借閱人 【@(item.Name)】 註銷嗎？')">
                                            註銷
                                        </button>
                                    </form>
                                }
                                else if (item.PtrStatus == 4)
                                {
                                    <form asp-action="UpdateStatus" asp-route-id="@item.PatronID" asp-route-status="1" class="d-inline">
                                        <button type="submit" class="btn btn-outline-success" onclick="return confirm('確定要將借閱人 【@(item.Name)】 恢復正常嗎？')">
                                            還原
                                        </button>
                                    </form>
                                }

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

