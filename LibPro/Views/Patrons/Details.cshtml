@model LibPro.Models.Patrons

@{
    ViewData["Title"] = "借閱人詳細資料";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-person-vcard me-2"></i>@ViewData["Title"]</h3>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-return-left"></i> 返回列表
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-3">

                <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-person-circle me-2"></i> @Model.Name

                        <span class="fs-6 fw-normal ms-3 text-white">
                            (@Model.PatronsStatus.StatusName)
                        </span>
                    </h5>
                </div>

                <div class="card-body p-4">
                    <div class="row g-4">

                        <div class="col-md-6">
                            <h6 class="text-primary fw-bold border-bottom pb-2 mb-3">個人基本資料</h6>
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <th class="text-muted" style="width: 120px;">借閱人編號</th>
                                        <td class="fw-bold text-dark">@Model.PatronID</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">@Html.DisplayNameFor(m => m.Gender)</th>
                                        <td>@Model.Gender</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">@Html.DisplayNameFor(m => m.Birthday)</th>
                                        <td>@Html.DisplayFor(m => m.Birthday)</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">@Html.DisplayNameFor(m => m.Education)</th>
                                        <td>@Model.Education</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">@Html.DisplayNameFor(m => m.Profession)</th>
                                        <td>@Model.Profession</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="col-md-6">
                            <h6 class="text-primary fw-bold border-bottom pb-2 mb-3">聯絡與系統資訊</h6>
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <th class="text-muted" style="width: 120px;">登入帳號</th>
                                        <td>
                                            <span class="font-monospace text-primary fw-bold">
                                                @Model.UserID
                                            </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">@Html.DisplayNameFor(m => m.Phone)</th>
                                        <td>@Model.Phone</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">@Html.DisplayNameFor(m => m.Email)</th>
                                        <td>@Model.Email</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="col-12 mt-2">
                            <h6 class="text-primary fw-bold border-bottom pb-2 mb-3">其他資訊</h6>
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <th class="text-muted" style="width: 120px;">聯絡地址</th>
                                        <td>@Model.ZipCode @Model.City.CityName @Model.District @Model.Address</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">@Html.DisplayNameFor(m => m.Memo)</th>
                                        <td>@Model.Memo</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

                <div class="card-footer bg-light text-end py-3 border-top-0 rounded-bottom-3">
                    <a asp-action="Edit" asp-route-id="@Model.PatronID"  class="btn btn-warning fw-bold px-4 text-dark shadow-sm">
                        <i class="bi bi-pencil-square"></i> 編輯此借閱人
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>