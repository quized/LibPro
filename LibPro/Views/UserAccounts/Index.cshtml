@model IEnumerable<LibPro.Models.UserAccounts>

@{
    ViewData["Title"] = "系統帳號管理";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0"><i class="bi bi-shield-lock-fill me-2 text-primary"></i>@ViewData["Title"]</h3>
        <span class="text-muted small">為維護系統安全，強制變更帳號或重設密碼前，請務必落實當事人身分核對程序。</span>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="mb-0 fw-bold text-muted"><i class="bi bi-list-ul me-1"></i> 帳號列表</h6>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-4">登入帳號</th>
                        <th class="py-3">使用者姓名</th>
                        <th>系統編號</th>
                        <th>權限身分</th>
                        <th>最後登入時間</th>
                        <th class="text-end pe-5">操作選項</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">@item.Account</td>

                            <td class="fw-bold text-primary">
                                @if (item.UserType == 1 || item.UserType == 2)
                                {
                                    <i class="bi bi-person-vcard me-1 text-muted"></i>
                                    @item.Staffs.First().Name
                                }
                                else
                                {
                                    <i class="bi bi-person me-1 text-muted"></i>
                                    @item.Patrons.First().Name
                                }
                            </td>

                            <td class="text-muted font-monospace">@item.UserID</td>
                            <td>
                                @if (item.UserType == 1)
                                {
                                    <span class="badge bg-danger">管理員</span>
                                }
                                else if (item.UserType == 2)
                                {
                                    <span class="badge bg-primary">一般館員</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">讀者</span>
                                }
                            </td>
                            <td class="text-muted small">
                                @(item.LastLoginTime.HasValue? item.LastLoginTime.Value.ToString("yyyy-MM-dd HH:mm") : "從未登入")
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-outline-primary px-3" data-bs-toggle="modal" data-bs-target="#editUserModal-@item.UserID">
                                    <i class="bi bi-key-fill"></i> 變更設定
                                </button>
                            </td>
                        </tr>

                        <div class="modal fade" id="editUserModal-@item.UserID" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 shadow">
                                    <form asp-action="Edit" method="post" onsubmit="return validatePassword('@item.UserID')">
                                        <div class="modal-header bg-light">
                                            <h5 class="modal-title fw-bold text-dark"><i class="bi bi-person-gear me-2 text-primary"></i>變更帳號設定</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>

                                        <div class="modal-body p-4">
                                            <input type="hidden" name="UserID" value="@item.UserID" />

                                            <div class="alert alert-warning py-2 small mb-3">
                                                <i class="bi bi-exclamation-circle me-1"></i> 若不修改密碼，請將密碼欄位留空。
                                            </div>

                                            <div class="form-group mb-3">
                                                <label class="form-label fw-bold text-muted">登入帳號 <span class="text-danger">*</span></label>
                                                <input name="Account" value="@item.Account" class="form-control" required minlength="8" maxlength="30" />
                                            </div>

                                            <div class="form-group mb-3">
                                                <label class="form-label fw-bold text-muted">新密碼</label>
                                                <div class="input-group">
                                                    <input type="password" id="NewPassword-@item.UserID" name="NewPassword" class="form-control border-end-0" minlength="8" placeholder="請輸入新密碼 (至少 8 碼)" />

                                                    <span class="input-group-text bg-white border-start-0 toggle-password" style="cursor: pointer;" data-target="NewPassword-@item.UserID">
                                                        <i class="bi bi-eye text-muted"></i>
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="form-group mb-2">
                                                <label class="form-label fw-bold text-muted">確認新密碼</label>
                                                <div class="input-group">
                                                    <input type="password" id="ConfirmPassword-@item.UserID" name="ConfirmPassword" class="form-control border-end-0" placeholder="請再次輸入新密碼" />

                                                    <span class="input-group-text bg-white border-start-0 toggle-password" style="cursor: pointer;" data-target="ConfirmPassword-@item.UserID">
                                                        <i class="bi bi-eye text-muted"></i>
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="modal-footer bg-light">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                                                <button type="submit" class="btn btn-primary fw-bold">儲存變更</button>
                                            </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script>
        // 前端驗證密碼是否一致
        function validatePassword(userId) {
            const pwd = document.getElementById('NewPassword-' + userId).value;
            const confirm = document.getElementById('ConfirmPassword-' + userId).value;

            if (pwd !== "" && pwd !== confirm) {
                alert("【錯誤】兩次輸入的密碼不一致，請重新檢查！");
                return false;
            }
            return true;
        }

        // 密碼顯示/隱藏
        $(document).ready(function () {
            $('.toggle-password').click(function () {
                const targetId = $(this).data('target');
                const $input = $('#' + targetId);
                const $icon = $(this).find('i');


                if ($input.attr('type') === 'password') {
                    $input.attr('type', 'text');
                    $icon.removeClass('bi-eye').addClass('bi-eye-slash');
                    return;
                }


                $input.attr('type', 'password');
                $icon.removeClass('bi-eye-slash').addClass('bi-eye');
            });
        });

    </script>
}