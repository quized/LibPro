@model IEnumerable<LibPro.Models.Announcements>

@{
    ViewData["Title"] = "圖書館公告總覽";
    Layout = "_HomeLayout";
    int i = 0;
}

<div class="container" style="margin-top: 3rem; margin-bottom: 5rem;">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2">
        <h2 class="text-primary fw-bold mb-0">
            <i class="bi bi-megaphone me-2"></i> 圖書館公告總覽
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill btn-sm px-3">
            <i class="bi bi-arrow-left me-1"></i> 返回首頁
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-3 p-md-4">
            @if (Model.Any())
            {
                <div class="accordion accordion-flush" id="announcementAccordion">                  
                    @foreach (var item in Model)
                    {
                        string collapseId = "collapse_" + i;
                        string headingId = "heading_" + i;

                        <div class="accordion-item border-bottom custom-hover-bg">
                            <h2 class="accordion-header" id="@headingId">
                                <button class="accordion-button collapsed bg-transparent shadow-none py-4" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                    <div class="d-flex align-items-center w-100 pe-3">
                                        <span class="badge bg-info text-white rounded-pill px-3 py-2 me-3 fw-normal" style="letter-spacing: 1px;">
                                            公告
                                        </span>
                                        <span class="fs-5 text-dark fw-semibold flex-grow-1" title="@item.Title">
                                            @item.Title
                                        </span>
                                        <span class="text-muted text-nowrap ms-3 d-none d-md-block" style="font-family: Arial, sans-serif;">
                                            <i class="bi bi-clock me-1"></i> @item.CreatedDate.ToString("yyyy-MM-dd")
                                        </span>
                                    </div>
                                </button>
                            </h2>
                            <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#announcementAccordion">
                                <div class="accordion-body px-4 py-4 px-md-5 text-secondary bg-light rounded-bottom" style="line-height: 1.8; font-size: 1.05rem;">
                                    @Html.Raw(item.Content?.Replace("\n", "<br />"))
                                </div>
                            </div>
                        </div>
                        i++;
                    }
                </div>
            }
            else
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                    <h5>目前尚無任何公告</h5>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* 增加標題列 hover 效果提升互動感 */
    .custom-hover-bg:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease-in-out;
    }
    /* 微調手風琴箭頭的位置與顏色 */
    .accordion-button:not(.collapsed) {
        color: #0d6efd;
        background-color: transparent;
        box-shadow: none;
    }
</style>