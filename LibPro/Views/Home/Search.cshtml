@model IEnumerable<LibPro.Models.Biblios>

@{
    ViewData["Title"] = "館藏查詢結果";
    Layout = "_PortalLayout";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">
        <i class="bi bi-search text-primary me-2"></i>館藏查詢
    </h2>

    <div class="row justify-content-center mb-5 mt-2">
        <div class="col-lg-8 col-md-10">
            <form asp-controller="Home" asp-action="Search" method="get" class="d-flex bg-white shadow-sm rounded-pill p-2 border border-light" style="transition: all 0.3s ease;" onmouseover="this.classList.add('shadow')" onmouseout="this.classList.remove('shadow', 'shadow-sm'); this.classList.add('shadow-sm')">
                <div class="input-group align-items-center">
                    <span class="input-group-text bg-transparent border-0 ps-4 text-primary">
                        <i class="bi bi-search fs-5"></i>
                    </span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control form-control-lg border-0 bg-transparent px-3" placeholder="輸入書名、作者、關鍵字或 ISBN..." style="box-shadow: none; outline: none;">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">
                        搜尋
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center rounded-4 py-4">
            <i class="bi bi-emoji-frown fs-2 d-block mb-2"></i>
            <h4>找不到符合「@ViewData["CurrentFilter"]」的館藏</h4>
            <p class="mb-0">請嘗試使用其他關鍵字搜尋。</p>
        </div>
    }
    else
    {
        <p class="text-muted">共找到 <strong>@Model.Count()</strong> 筆館藏結果</p>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden book-card">
                        <div class="d-flex justify-content-center align-items-center bg-light p-3" style="height: 250px;">

                            <img src="/ImgPath/@item.ImgPath"
                                 onerror="this.onerror=null; this.src='/ImgPath/bookcover.jpg';"
                                 class="shadow-sm" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="@item.BTitle">

                        </div>

                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary mb-2 align-self-start">@(item.Category.CatName)</span>
                            <h5 class="card-title fw-bold text-truncate" title="@item.BTitle">@item.BTitle</h5>
                            <p class="card-text text-muted small mb-1"><i class="bi bi-person me-1"></i>@(item.Author)</p>
                            <p class="card-text text-muted small mb-3"><i class="bi bi-upc-scan me-1"></i>@(item.ISBN)</p>

                            <div class="mt-auto pt-3 border-top">
                                <a asp-action="BookDetails" asp-route-id="@item.BibID" class="btn btn-outline-primary w-100 rounded-pill">
                                    查看詳情 / 預約
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
