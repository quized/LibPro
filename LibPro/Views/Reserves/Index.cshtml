@model IEnumerable<LibPro.Models.Reserves>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ResDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ExpiryDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReserveStatus)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Patron)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BookItem)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ResDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ExpiryDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Notes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReserveStatus.StatusName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Patron.PatronID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BookItem.ItemID)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ResID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ResID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ResID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
