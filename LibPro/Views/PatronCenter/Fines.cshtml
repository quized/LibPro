@model IEnumerable<LibPro.ViewModels.PatronFineViewModel>

@{
    ViewData["Title"] = "罰金紀錄";
    Layout = "_PatronLayout";
    decimal totalUnpaid = 0;

    if (ViewBag.TotalUnpaid != null)
    {
        totalUnpaid = ViewBag.TotalUnpaid;
    }
}

@if (totalUnpaid > 0)
{
    <div class="alert alert-danger shadow-sm border-0 rounded-4 mb-4 d-flex align-items-center p-4">
        <i class="bi bi-exclamation-triangle-fill text-danger opacity-75 me-4" style="font-size: 3rem;"></i>
        <div>
            <h4 class="alert-heading fw-bold mb-1 text-danger">未繳罰金總額：$@totalUnpaid.ToString("0")</h4>
            <p class="mb-0 text-dark">您目前尚有未結清之罰金，請盡速至圖書館櫃檯繳納，以恢復您的完整借閱權限。</p>
        </div>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <h4 class="fw-bold text-dark mb-0">
            <i class="bi bi-cash-coin text-warning me-2"></i>我的罰金紀錄
        </h4>
    </div>
    <div class="card-body p-4">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-check2-circle text-success opacity-50" style="font-size: 5rem;"></i>
                <h5 class="fw-bold mt-3 text-secondary">您目前沒有任何罰金紀錄</h5>
                <p class="text-muted">請繼續保持良好的借閱習慣，享受閱讀的樂趣吧！</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center">
                    <thead class="table-light text-muted small">
                        <tr>
                            <th class="text-start rounded-start ps-3">產生日期</th>
                            <th class="text-start">書名</th>
                            <th>罰款類型</th>
                            <th>逾期天數</th>
                            <th class="text-end">金額</th>
                            <th class="rounded-end">狀態</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-start text-secondary small ps-3">
                                    @item.CreatedDate.ToString("yyyy-MM-dd")
                                </td>
                                <td class="text-start fw-bold text-dark">
                                    @item.BookTitle
                                </td>
                                <td>
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border">@item.FineTypeName</span>
                                </td>
                                <td>
                                    @if (item.FineTypeName == "逾期" && item.OverdueDays > 0)
                                    {
                                        <span class="text-danger fw-bold">@item.OverdueDays 天</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end fw-bold font-monospace text-dark">
                                    @if (item.Amount > 0)
                                    {
                                        <span>$@item.Amount.ToString("0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsPaid)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2">
                                            <i class="bi bi-check-circle-fill me-1"></i>已結清
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm">
                                            <i class="bi bi-exclamation-circle-fill me-1"></i>未繳款
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>