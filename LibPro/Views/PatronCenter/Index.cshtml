@model LibPro.Models.Patrons

@{
    ViewData["Title"] = "個人資料 - 讀者中心";
    Layout = "_PatronLayout";
}

<div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
    <div class="bg-primary bg-gradient p-5" style="height: 140px; opacity: 0.9;"></div>

    <div class="card-body p-4 p-md-5 position-relative pt-0">
        <div class="d-flex align-items-end mb-5" style="margin-top: -50px;">
            <div class="bg-white p-2 rounded-circle shadow-sm me-4">
                <div class="bg-light text-primary rounded-circle d-flex justify-content-center align-items-center" style="width: 100px; height: 100px;">
                    <i class="bi bi-person-fill fs-1"></i>
                </div>
            </div>
            <div class="pb-2">
                <h3 class="fw-bold text-dark mb-2">@Html.DisplayFor(model => model.Name)</h3>
                <div class="d-flex align-items-center flex-wrap gap-2">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1">
                        <i class="bi bi-check-circle-fill me-1"></i>帳號啟用中
                    </span>
                    <span class="badge bg-light text-secondary border px-2 py-1 font-monospace fs-6">
                        <i class="bi bi-upc-scan me-1"></i>證號：@Html.DisplayFor(model => model.PatronID)
                    </span>
                </div>
            </div>
        </div>

        <h5 class="fw-bold mb-4 text-secondary border-bottom pb-3">
            <i class="bi bi-card-text me-2"></i>聯絡資訊
        </h5>

        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <div class="p-3 border rounded-3 bg-light bg-opacity-50 h-100">
                    <label class="text-muted small fw-bold d-block mb-2">
                        <i class="bi bi-telephone text-primary me-2"></i>聯絡電話
                    </label>
                    <span class="fs-6 text-dark fw-medium">
                        @Html.DisplayFor(model => model.Phone)
                    </span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded-3 bg-light bg-opacity-50 h-100">
                    <label class="text-muted small fw-bold d-block mb-2">
                        <i class="bi bi-envelope text-primary me-2"></i>電子信箱
                    </label>
                    <span class="fs-6 text-dark fw-medium">
                       @Html.DisplayFor(model => model.Email)
                    </span>
                </div>
            </div>

            <div class="col-12">
                <div class="p-3 border rounded-3 bg-light bg-opacity-50 h-100">
                    <label class="text-muted small fw-bold d-block mb-2">
                        <i class="bi bi-house-door text-primary me-2"></i>通訊地址
                    </label>
                    <span class="fs-6 text-dark fw-medium">
                        @Html.DisplayFor(model => model.City.CityName)@Html.DisplayFor(model => model.Address)
                    </span>
                </div>
            </div>
        </div>

        <div class="mt-auto p-4 bg-primary bg-opacity-10 rounded-4 border border-primary border-opacity-25 d-flex align-items-center">
            <i class="bi bi-info-circle-fill text-primary fs-2 me-3 d-none d-sm-block"></i>
            <div>
                <h6 class="fw-bold text-primary mb-1">需要更新個人資料嗎？</h6>
                <p class="text-primary text-opacity-75 small mb-0">
                    為保障您的借閱權益與帳號安全，若上述聯絡資訊有異動，請攜帶身分證件至本館一樓綜合服務櫃檯由櫃檯人員為您辦理變更。
                </p>
            </div>
        </div>

    </div>
</div>