@model IEnumerable<LibPro.Models.Reserves>

@{
    ViewData["Title"] = "預約清單 - 讀者中心";
    Layout = "_PatronLayout";
}


<div class="card shadow-sm border-0 rounded-4 p-4 h-100">
    <h4 class="fw-bold mb-4"><i class="bi bi-bookmark-fill text-primary me-2"></i>我的預約清單</h4>

    @if (!Model.Any())
    {
        <div class="text-center p-5 text-muted my-auto">
            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
            <h5>您目前沒有任何預約紀錄</h5>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-3 rounded-pill px-4">
                去找本書來預約吧！
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-3 py-3">書名</th>
                        <th class="py-3">@Html.DisplayNameFor(model => model.FirstOrDefault().ItemID)</th>
                        <th class="py-3">@Html.DisplayNameFor(model => model.FirstOrDefault().ResDate)</th>
                        <th class="py-3">@Html.DisplayNameFor(model => model.FirstOrDefault().ExpiryDate)</th>
                        <th class="py-3">狀態</th>
                        <th class="pe-3 py-3 text-end">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold text-dark">
                                <a asp-controller="Home" asp-action="BookDetails" asp-route-id="@item.BookItem.BibID" class="text-decoration-none text-primary" title="查看書籍詳情">
                                    @(item.BookItem.Biblio.BTitle)
                                </a>
                            </td>
                            <td class="text-secondary font-monospace">@Html.DisplayFor(modelItem => item.ItemID)</td>
                            <td class="text-muted small">@item.ResDate.ToString("yyyy-MM-dd")</td>
                            <td class="text-muted small">@item.ExpiryDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (item.ResStatus == 1)
                                {
                                    <span class="badge bg-warning text-dark border border-warning px-2 py-1">
                                        <i class="bi bi-hourglass-split me-1"></i>@(item.ReserveStatus.StatusName)
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-2 py-1">
                                        @(item.ReserveStatus.StatusName)
                                    </span>
                                }
                            </td>
                            <td class="pe-3 text-end">
                                @if (item.ResStatus == 1)
                                {
                                    <form asp-action="Cancel" method="post" class="d-inline" onsubmit="return confirm('確定要取消這筆《@(item.BookItem.Biblio.BTitle)》的預約嗎？');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="resId" value="@item.ResID" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                            取消
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>