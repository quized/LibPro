@model LibPro.Models.Loans

@{
    ViewData["Title"] = "借書作業 (Check-Out)";
}

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h2><i class="bi bi-book"></i> 櫃台借書作業</h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">1. 掃描區</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" id="checkoutForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label asp-for="PatronID" class="control-label fw-bold text-primary">借閱人證號</label>
                            <input asp-for="PatronID" class="form-control form-control-lg border-primary" placeholder="請刷入借閱證條碼..." autofocus />
                            <span asp-validation-for="PatronID" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ItemID" class="control-label fw-bold text-success">書籍條碼</label>
                            <input asp-for="ItemID" class="form-control form-control-lg border-success" placeholder="請刷入書籍條碼..." />
                            <span asp-validation-for="ItemID" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Notes" class="control-label fw-bold text-muted">備註 (選填)</label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="如有破損或其他狀況可記錄於此"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">確認借出</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> 返回借閱紀錄列表</a>
            </div>
        </div>

        <div class="col-md-8">
            <div class="alert alert-info shadow-sm" role="alert">
                <h5 class="alert-heading mb-1"><i class="bi bi-person-badge"></i> 讀者狀態：請先掃描借閱證</h5>
                <p class="mb-0 text-muted" id="patronStatusText">目前尚未載入讀者資訊。</p>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0 text-dark"><i class="bi bi-list-check"></i> 本次借閱清單</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th width="10%">#</th>
                                <th width="30%">書籍條碼</th>
                                <th width="40%">書名 (預覽)</th>
                                <th width="20%" class="text-center">操作</th>
                            </tr>
                        </thead>
                        <tbody id="scannedItemsList">
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    目前尚無掃描書籍，請於左側輸入書籍條碼。
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}