@model LibPro.Models.Loans

@{
    ViewData["Title"] = "借閱明細";

    // 狀態邏輯判斷
    bool isReturned = Model.ReturnDate.HasValue;
    bool isOverdue = !isReturned && Model.DueDate.Date < DateTime.Now.Date;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-3">

                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-receipt"></i> 借閱單號：@Model.LoanID
                    </h5>
                    <div>
                        @if (isReturned)
                        {
                            <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> 已結案 (歸還)</span>
                        }
                        else if (isOverdue)
                        {
                            <span class="badge bg-danger fs-6 animate__animated animate__pulse animate__infinite"><i class="bi bi-exclamation-triangle"></i> 逾期未還</span>
                        }
                        else
                        {
                            <span class="badge bg-primary fs-6"><i class="bi bi-book"></i> 借閱中</span>
                        }
                    </div>
                </div>

                <div class="card-body p-4">
                    <h6 class="text-secondary fw-bold border-bottom pb-2 mb-3">
                        <i class="bi bi-info-square"></i> 核心資訊
                    </h6>
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <p class="mb-1 text-muted small">借閱人證號</p>
                            <p class="fs-5 fw-bold">@Model.PatronID</p>
                        </div>
                        <div class="col-sm-6">
                            <p class="mb-1 text-muted small">書籍條碼</p>
                            <p class="fs-5 fw-bold text-primary">
                                <i class="bi bi-upc-scan"></i> @Model.ItemID
                            </p>
                        </div>
                    </div>

                    <h6 class="text-secondary fw-bold border-bottom pb-2 mb-3">
                        <i class="bi bi-clock-history"></i> 時間軌跡
                    </h6>
                    <div class="row mb-4 bg-light p-3 rounded-3">
                        <div class="col-sm-4 text-center border-end">
                            <p class="mb-1 text-muted small">借出時間</p>
                            <p class="mb-0 fw-bold">@Model.LoanDate.ToString("yyyy/MM/dd HH:mm")</p>
                        </div>
                        <div class="col-sm-4 text-center border-end">
                            <p class="mb-1 text-muted small">應還日期</p>
                            <p class="mb-0 fw-bold @(isOverdue ? "text-danger" : "")">
                                @Model.DueDate.ToString("yyyy/MM/dd")
                            </p>
                        </div>
                        <div class="col-sm-4 text-center">
                            <p class="mb-1 text-muted small">實際歸還時間</p>
                            @if (Model.ReturnDate.HasValue)
                            {
                                <p class="mb-0 fw-bold text-success">@Model.ReturnDate.Value.ToString("yyyy/MM/dd HH:mm")</p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted">尚未歸還</p>
                            }
                        </div>
                    </div>

                    <h6 class="text-secondary fw-bold border-bottom pb-2 mb-3">
                        <i class="bi bi-card-text"></i> 其他紀錄
                    </h6>
                    <div class="row">
                        <div class="col-sm-4">
                            <p class="mb-1 text-muted small">續借次數</p>
                            <p class="mb-0">
                                <span class="badge bg-info text-dark rounded-pill">@Model.RenewalCount 次</span>
                            </p>
                        </div>
                        <div class="col-sm-8">
                            <p class="mb-1 text-muted small">備註</p>
                            @if (string.IsNullOrWhiteSpace(Model.Notes))
                            {
                                <p class="mb-0 text-muted fst-italic">無備註紀錄</p>
                            }
                            else
                            {
                                <div class="p-2 border border-warning rounded-2 bg-warning bg-opacity-10 text-dark">
                                    @Model.Notes
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white text-end py-3">
                    <a asp-action="Index" class="btn btn-outline-secondary me-2">
                        <i class="bi bi-arrow-left"></i> 回總覽清單
                    </a>

                    @if (!isReturned)
                    {
                        <a asp-action="CheckIn" class="btn btn-success shadow-sm">
                            <i class="bi bi-box-arrow-in-right"></i> 前往還書作業
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>