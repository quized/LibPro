@model IEnumerable<LibPro.Models.Loans>

@{
    ViewData["Title"] = "借閱紀錄總覽";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 text-dark fw-bold">
            <i class="bi bi-journal-text text-primary"></i> 借閱紀錄總覽
        </h2>
        <div>
            <a asp-action="CheckOut" class="btn btn-primary shadow-sm me-2">
                <i class="bi bi-upc-scan"></i> 借書作業 (Check-Out)
            </a>
            <a asp-action="CheckIn" class="btn btn-success shadow-sm">
                <i class="bi bi-box-arrow-in-right"></i> 還書作業 (Check-In)
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0 table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">狀態</th>
                        <th>借閱人證號</th>
                        <th>書籍條碼</th>
                        <th>應還日期</th>
                        <th class="text-center">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-folder2-open fs-1 d-block mb-3"></i>
                                目前尚無任何借閱紀錄
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        bool isReturned = item.ReturnDate.HasValue;
                        bool isOverdue = !isReturned && item.DueDate.Date < DateTime.Now.Date;

                        <tr>
                            <td class="ps-4">
                                @if (isReturned)
                                {
                                    <span class="badge bg-success px-2 py-1"><i class="bi bi-check-circle"></i> 已歸還</span>
                                }
                                else if (isOverdue)
                                {
                                    <span class="badge bg-danger px-2 py-1 animate__animated animate__pulse animate__infinite"><i class="bi bi-exclamation-triangle"></i> 逾期未還</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary px-2 py-1"><i class="bi bi-book"></i> 借閱中</span>
                                }

                                @if (!string.IsNullOrEmpty(item.Notes))
                                {
                                    <i class="bi bi-chat-dots-fill text-warning ms-2" data-bs-toggle="tooltip" title="@item.Notes" style="cursor: help;"></i>
                                }
                            </td>

                            <td class="fw-bold text-secondary">@item.PatronID</td>
                            <td><span class="badge bg-light text-dark border border-secondary fs-6">@item.ItemID</span></td>

                            <td class="@(isOverdue ? "text-danger fw-bold" : "")">
                                @item.DueDate.ToString("yyyy/MM/dd")
                            </td>

                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.LoanID" class="btn btn-sm btn-outline-secondary shadow-sm">
                                    <i class="bi bi-search"></i> 完整明細
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>