@using LibPro.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = "系統登入";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 圖書館管理系統</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <style>
        body {
            background-image: url(/ImgPath/LoginBG.jpg);
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            margin: 0;
        }

        .bg-overlay {
            background-color: rgba(0, 0, 0, 0.4);
            min-height: 100vh;
            width: 100%;
        }
    </style>
</head>
<body>
    <div class="bg-overlay d-flex align-items-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-4">
                    <div class="card shadow border-0" style="border-radius: 10px; overflow: hidden;">
                        <div class="card-header bg-primary text-white text-center py-3">
                            <h4 class="mb-0">書不了登入系統</h4>
                        </div>
                        <div class="card-body p-4 bg-white">
                            <form asp-action="Login" method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                                <div class="form-group mb-3">
                                    <label asp-for="Account" class="control-label fw-bold"></label>
                                    <input asp-for="Account" class="form-control" placeholder="請輸入您的帳號 (預設為手機)" />
                                    <span asp-validation-for="Account" class="text-danger"></span>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="Password" class="control-label fw-bold"></label>

                                    <div class="input-group">
                                        <input asp-for="Password" class="form-control border-end-0" type="password" placeholder="請輸入您的密碼" />

                                        <span class="input-group-text bg-white border-start-0 toggle-password" style="cursor: pointer;" data-target="Password">
                                            <i class="bi bi-eye text-muted"></i>
                                        </span>
                                    </div>

                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>

                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary btn-lg">登入系統</button>
                                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg">返回首頁</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.toggle-password').click(function () {
                const targetId = $(this).data('target');
                const $input = $('#' + targetId);
                const $icon = $(this).find('i');

             
                if ($input.attr('type') === 'password') {
                    $input.attr('type', 'text');
                    $icon.removeClass('bi-eye').addClass('bi-eye-slash');
                    return; 
                }

                
                $input.attr('type', 'password');
                $icon.removeClass('bi-eye-slash').addClass('bi-eye');
            });
        });
    </script>
</body>
</html>