@using LibPro.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = "系統登入";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 圖書館管理系統</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light d-flex align-items-center" style="height: 100vh;">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white text-center py-3">
                        <h4 class="mb-0">圖書館後台管理系統</h4>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                            <div class="form-group mb-3">
                                <label asp-for="Account" class="control-label fw-bold"></label>
                                <input asp-for="Account" class="form-control" placeholder="請輸入您的帳號 (預設為手機)" />
                                <span asp-validation-for="Account" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Password" class="control-label fw-bold"></label>
                                <input asp-for="Password" class="form-control" placeholder="請輸入您的密碼" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">登入系統</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>