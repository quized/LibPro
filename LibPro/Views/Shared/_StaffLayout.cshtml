<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 書不了管理後台</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibPro.styles.css" asp-append-version="true" />
</head>
<body class="staff-layout">

    <aside class="staff-sidebar d-flex flex-column p-3 shadow">

        <a asp-area="" asp-controller="Home" asp-action="StaffCenter" class="d-flex align-items-center mb-4 text-white text-decoration-none">
            <i class="bi bi-book-half fs-3 me-2 text-warning"></i>
            <span class="fs-4 fw-bold tracking-wide">書不了管理後台</span>
        </a>

        <hr class="text-white-50 mt-0 mb-3">

        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item mt-2 mb-1">
                <small class="text-white-50 fw-bold px-3">流通服務</small>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Loans" asp-action="CheckOut">
                    <i class="bi bi-upc-scan me-2"></i> 借書作業
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Loans" asp-action="CheckIn">
                    <i class="bi bi-upc me-2"></i> 還書作業
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Reserves" asp-action="Index">
                    <i class="bi bi-clock-history me-2"></i> 預約管理
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Fines" asp-action="Index">
                    <i class="bi bi-cash-coin me-2"></i> 罰金繳納
                </a>
            </li>

            <li class="nav-item mt-3 mb-1">
                <small class="text-white-50 fw-bold px-3">讀者與館藏</small>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Patrons" asp-action="Index">
                    <i class="bi bi-person-vcard me-2"></i> 借閱人管理
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Biblios" asp-action="Index">
                    <i class="bi bi-journal-text me-2"></i> 書目管理
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="BookItems" asp-action="Index">
                    <i class="bi bi-box-seam me-2"></i> 館藏管理
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Reviews" asp-action="Index">
                    <i class="bi bi-chat-square-text me-2"></i> 書評審核
                </a>
            </li>

            <li class="nav-item mt-3 mb-1">
                <small class="text-white-50 fw-bold px-3">系統設定</small>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Categories" asp-action="Index">
                    <i class="bi bi-tags me-2"></i> 類別管理
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Publishers" asp-action="Index">
                    <i class="bi bi-buildings me-2"></i> 出版社管理
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Locations" asp-action="Index">
                    <i class="bi bi-geo-alt me-2"></i> 位置管理
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link py-2 px-3" asp-controller="Announcements" asp-action="Index">
                    <i class="bi bi-megaphone me-2"></i> 公告管理
                </a>
            </li>
        </ul>

        <hr class="text-white-50">

        <div class="px-3 py-2">
            <a asp-controller="Login" asp-action="Logout" class="text-white text-decoration-none small">
                <i class="bi bi-box-arrow-left me-2"></i> 登出系統
            </a>
        </div>
    </aside>

    <div class="staff-main-content">
        <main role="main" class="flex-grow-1 p-4 p-md-5">
            @RenderBody()
        </main>

        <footer class="border-top text-muted py-3 px-4 px-md-5 bg-white mt-auto d-flex flex-wrap justify-content-between align-items-center">
            <div class="small">
                &copy; @DateTime.Now.Year <strong>LibPro</strong> 圖書資訊管理系統 <span class="text-black-50 ms-1">| 館員作業中心</span>
            </div>
            <div class="small d-flex align-items-center mt-2 mt-md-0">
                <span class="me-4 text-secondary">
                    <i class="bi bi-cpu me-1"></i> 版本: v1.0.0
                </span>
                <a href="#" class="text-decoration-none text-muted me-4 link-primary">
                    <i class="bi bi-journal-bookmark me-1"></i> 操作手冊
                </a>
                <a href="#" class="text-decoration-none text-muted link-danger">
                    <i class="bi bi-headset me-1"></i> 聯絡技術支援
                </a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>