<div class="modal fade" id="globalChangePwdModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-key-fill me-2"></i>變更我的登入密碼</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">

                <div id="pwdAlertArea" class="alert d-none shadow-sm" role="alert"></div>

                <form id="changePwdForm">
                    @Html.AntiForgeryToken()

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold text-muted">目前密碼</label>
                        <div class="input-group">
                            <input type="password" id="oldPassword" name="oldPassword" class="form-control border-end-0 bg-light" required placeholder="請輸入原密碼" />
                            <span class="input-group-text bg-light border-start-0 toggle-password" style="cursor: pointer;" data-target="oldPassword">
                                <i class="bi bi-eye text-muted"></i>
                            </span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold text-muted">新密碼</label>
                        <div class="input-group">
                            <input type="password" id="NewPassword" name="NewPassword" class="form-control border-end-0" minlength="8" placeholder="請輸入新密碼 (至少 8 碼)" />
                            <span class="input-group-text bg-white border-start-0 toggle-password" style="cursor: pointer;" data-target="NewPassword">
                                <i class="bi bi-eye text-muted"></i>
                            </span>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold text-muted">確認新密碼</label>
                        <div class="input-group">
                            <input type="password" id="ConfirmPassword" name="ConfirmPassword" class="form-control border-end-0" placeholder="請再次輸入新密碼" />
                            <span class="input-group-text bg-white border-start-0 toggle-password" style="cursor: pointer;" data-target="ConfirmPassword">
                                <i class="bi bi-eye text-muted"></i>
                            </span>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary fw-bold" id="btnSubmitPwd">確認修改密碼</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("changePwdForm");
        const alertArea = document.getElementById("pwdAlertArea");
        const btnSubmit = document.getElementById("btnSubmitPwd");

        form.addEventListener("submit", function (e) {
            e.preventDefault();


            if (form.oldPassword.value === form.NewPassword.value) {
                showAlert("新密碼不可與目前密碼相同！", "danger");
                return;
            }

  
            if (form.NewPassword.value !== form.ConfirmPassword.value) {
                showAlert("兩次輸入的新密碼不一致！", "danger");
                return;
            }

            const originalBtnText = btnSubmit.innerHTML;
            btnSubmit.disabled = true;
            btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>處理中...';

            const formData = new FormData(form);

            fetch('/Login/ChangePasswordAPI', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (!data.success) {
                    showAlert(data.message, "danger");
                    btnSubmit.disabled = false;
                    btnSubmit.innerHTML = originalBtnText;
                    return;
                }
                   showAlert(data.message, "success");
            form.reset();

            
            setTimeout(() => {
          
                const modalElement = document.getElementById('globalChangePwdModal');
                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                if (modalInstance) {
                    modalInstance.hide();
                }

          
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = '確認修改密碼';
                alertArea.classList.add('d-none');
                }, 1000);
                    })
                    .catch(error => {
                        showAlert("系統發生錯誤，請稍後再試或聯繫管理員。", "danger");
                        btnSubmit.disabled = false;
                        btnSubmit.innerHTML = originalBtnText;
                    });
        });

        function showAlert(msg, type) {
            alertArea.className = "alert alert-" + type + " shadow-sm";
            if (type === "danger") {
                alertArea.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i> ' + msg;
                return;
            }
            alertArea.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> ' + msg;
        }

        // 密碼顯示/隱藏
        const toggleButtons = document.querySelectorAll('.toggle-password');
        toggleButtons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const input = document.getElementById(targetId);
                const icon = this.querySelector('i');

                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('bi-eye');
                    icon.classList.add('bi-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                }
            });
        });
    });
</script>