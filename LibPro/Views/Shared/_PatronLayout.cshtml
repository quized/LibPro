<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 借閱人中心</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibPro.styles.css" asp-append-version="true" />

    <style>

        /* 確保滿版高度與背景色 */
        .patron-body {
            height: 100%;
            background-color: #f8f9fa;
        }

        /* 左側選單固定樣式 */
        .patron-sidebar {
            width: 280px;
            min-height: 100vh;
            position: sticky;
            top: 0;
            background-color: #ffffff;
            box-shadow: 2px 0 10px rgba(0,0,0,0.05);
            z-index: 1000;
        }

        /* 右側主內容區塊 */
        .patron-main-content {
            flex-grow: 1;
            min-height: 100vh;
        }

        /* 美化選單按鈕 */
        .patron-nav-link {
            display: block;
            padding: 0.5rem 1rem;
            text-decoration: none;
            border-radius: 0.5rem;
            margin-bottom: 0.25rem;
            color: #495057;
            transition: all 0.2s;
        }

            .patron-nav-link:hover {
                background-color: #f1f3f5;
                color: #0d6efd;
            }

            /* 當按鈕處於啟動狀態 (Active) 時的樣式 */
            .patron-nav-link.active {
                background-color: #0d6efd;
                color: white;
                box-shadow: 0 4px 6px rgba(13, 110, 253, 0.2);
            }
    </style>
</head>
<body class="patron-body">

    @{
        string currentAction = "";
        if (ViewContext.RouteData.Values["action"] != null)
        {
            currentAction = ViewContext.RouteData.Values["action"].ToString();
        }


        string CheckActive(string menuName)
        {
            if (currentAction == menuName)
            {
                return "active";
            }

            return "";

        }
    }

    <div class="d-flex">

        <div class="patron-sidebar d-flex flex-column flex-shrink-0 p-4">

            <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center mb-4 link-dark text-decoration-none" title="回前台首頁">
                <i class="bi bi-book-half fs-3 text-primary me-2"></i>
                <span class="fs-4 fw-bold text-dark">LibPro <span class="text-primary fs-6">借閱人中心</span></span>
            </a>

            <hr class="text-black-50 mb-4">

            <ul class="nav flex-column mb-auto list-unstyled">
                <li class="nav-item">
                    <a asp-controller="PatronCenter" asp-action="Index" class="patron-nav-link py-3 fw-medium @CheckActive("Index")">
                        <i class="bi bi-person-lines-fill me-3 fs-5"></i>
                        個人資料
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="PatronCenter" asp-action="Reserves" class="patron-nav-link py-3 fw-medium @CheckActive("Reserves")">
                        <i class="bi bi-bookmark-fill me-3 fs-5"></i>
                        預約紀錄
                    </a>
                </li>

                <li class="nav-item">
                    <a href="#" class="patron-nav-link py-3 fw-medium text-secondary" data-bs-toggle="modal" data-bs-target="#globalChangePwdModal">
                        <i class="bi bi-key  me-3 fs-5"></i>
                        修改密碼
                    </a>
                </li>
           
            </ul>

            <div class="mt-auto pt-4 border-top">
                <p class="text-muted small mb-0 text-center">&copy; 2026 LibPro System</p>
                <div class="text-center mt-2">
                    <a asp-controller="Login" asp-action="Logout" class="btn btn-outline-danger btn-sm rounded-pill w-100">
                        <i class="bi bi-box-arrow-right me-1"></i>登出
                    </a>
                </div>
            </div>
        </div>

        <div class="patron-main-content p-4 p-md-5">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-4" role="alert">
                    <i class="bi bi-x-circle-fill me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ChangePasswordModal" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>