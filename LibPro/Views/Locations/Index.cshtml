@model IEnumerable<LibPro.Models.Locations>

@{
    ViewData["Title"] = "館藏位置列表";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-geo-alt-fill me-2"></i>@ViewData["Title"]</h3>
        <button type="button" class="btn btn-primary fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#LocCreateModal">
            <i class="bi bi-plus-lg"></i> 新增位置
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.LocationName)</th>
                        <th>@Html.DisplayNameFor(model => model.Depth)</th>
                        <th>@Html.DisplayNameFor(model => model.SortOrder)</th>
                        <th>@Html.DisplayNameFor(model => model.ParentLocation)</th>
                        <th class="text-end pe-4">管理操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">
                                @Html.DisplayFor(modelItem => item.LocationName)
                            </td>
                            <td>
                                <span class="badge bg-secondary">@Html.DisplayFor(modelItem => item.Depth)</span>
                            </td>
                            <td class="text-muted">
                                @Html.DisplayFor(modelItem => item.SortOrder)
                            </td>
                            <td>
                                @if (item.ParentLocation != null)
                                {
                                    <span class="text-primary fw-bold">@item.ParentLocation.LocationName</span>
                                }
                                else
                                {
                                    <span class="text-muted small">--</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-outline-warning text-dark fw-bold" data-id="@item.LocationID" data-bs-toggle="modal" data-bs-target="#LocEditModal">
                                    <i class="bi bi-pencil-square"></i> 修改
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="LocCreateModal" tabindex="-1" aria-labelledby="LocCreateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="LocCreateModalLabel"><i class="bi bi-plus-lg"></i> 新增館藏位置</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="LocCreate"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="LocEditModal" tabindex="-1" aria-labelledby="LocEditModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold" id="LocEditModalLabel"><i class="bi bi-pencil-square"></i> 館藏位置變更</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="LocEdit"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // 當 Modal 開啟時載入 Create Partial View
        $('#LocCreateModal').on('show.bs.modal', function () {
            $('#LocCreate').load('/Locations/Create', function () {
                $.validator.unobtrusive.parse($('#LocCreate'));
            });

            // 每次關閉時清空內容
            $('#LocCreateModal').on('hidden.bs.modal', function () {
                $('#LocCreate').html('');
            });
        });

        $('#LocEditModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget); // 取得觸發 modal 的按鈕
            var locId = button.data('id');
            $('#LocEdit').html(''); // 先清空
            if (locId) {
                $('#LocEdit').load('/Locations/Edit/' + locId, function () {
                    $.validator.unobtrusive.parse($('#LocEdit'));
                });
            }
        });

        $('#LocEditModal').on('hidden.bs.modal', function () {
            $('#LocEdit').html('');
        });
    </script>
}