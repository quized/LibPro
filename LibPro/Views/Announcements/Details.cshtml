@model LibPro.Models.Announcements

@{
    ViewData["Title"] = "公告詳情";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-5">

                        <div class="d-flex justify-content-center align-items-center gap-3 mb-4 flex-wrap">
                            <h2 class="fw-bolder text-dark mb-0 lh-base">@Model.Title</h2>

                            @if (!Model.IsVisible)
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-3 py-2 rounded-pill fw-normal" title="此公告目前不在讀者首頁顯示">
                                    <i class="bi bi-eye-slash me-1"></i> 已隱藏
                                </span>
                            }
                        </div>

                        <div class="d-flex justify-content-center align-items-center text-muted small gap-3 gap-md-4 flex-wrap">
                            <span><i class="bi bi-upc-scan me-1"></i>@Model.AnnID</span>
                            <span><i class="bi bi-person-circle me-1"></i>@Model.Staff.Name</span>
                            <span><i class="bi bi-clock me-1"></i>@Model.CreatedDate.ToString("yyyy/MM/dd HH:mm")</span>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25 mb-5" />

                    <div class="text-dark lh-lg fs-6 mb-5 px-md-3" style="white-space: pre-wrap; word-wrap: break-word;">@Model.Content</div>

                    <div class="d-flex justify-content-center gap-3 pt-4 border-top">
                        <a asp-action="Index" class="btn btn-light border px-4 rounded-pill text-muted">
                            <i class="bi bi-arrow-left me-1"></i> 返回列表
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.AnnID" class="btn btn-primary px-5 rounded-pill shadow-sm">
                            <i class="bi bi-pencil-square me-1"></i> 編輯公告
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>