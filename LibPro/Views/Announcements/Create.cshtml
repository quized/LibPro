@model LibPro.Models.Announcements

@{
    ViewData["Title"] = "新增公告";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800">
            <i class="bi bi-megaphone me-2 text-primary"></i>發布新公告
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> 返回列表
        </a>
    </div>

    <div class="row justify-content-center mt-5">
        <div class="col-lg-8 col-xl-7">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="m-0 fw-bold text-primary">編輯公告內容</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="form-group mb-4">
                            <label asp-for="Title" class="form-label fw-bold text-dark"></label>
                            <input asp-for="Title" class="form-control form-control-lg bg-light" placeholder="請輸入公告標題..." autocomplete="off" />
                            <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-group mb-5">
                            <label asp-for="Content" class="form-label fw-bold text-dark"></label>
                            <textarea asp-for="Content" class="form-control bg-light" rows="13" placeholder="請輸入詳細公告內容..."></textarea>
                            <span asp-validation-for="Content" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center border-top pt-4 mt-2">
                            <a asp-action="Index" class="btn btn-light border text-muted px-4">
                                取消
                            </a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                <i class="bi bi-send-fill me-1"></i> 發布公告
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}